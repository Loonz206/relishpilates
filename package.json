{
  "name": "relish-pilates",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "CMS_PROVIDER=local-api CMS_LOCAL_BASE_URL=http://localhost:3001 concurrently -k \"yarn dev:web\" \"yarn mock-server:dev\"",
    "dev:web": "next dev",
    "dev:content": "CMS_PROVIDER=local-api CMS_LOCAL_BASE_URL=http://localhost:3001 concurrently -k \"yarn dev:web\" \"yarn mock-server:dev\"",
    "dev:contentful-mock": "CMS_PROVIDER=contentful-delivery CONTENTFUL_MOCK_BASE_URL=http://localhost:3002 concurrently -k \"yarn dev:web\" \"yarn mock-server:contentful\"",
    "content:health": "curl -sf http://localhost:3001/siteConfig | head -c 180 && echo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "mock-server": "json-server --watch db.json --port 3001",
    "mock-server:contentful": "json-server --watch db.contentful-mock.json --port 3002",
    "mock-server:dev": "nodemon --watch db.json --ext json --exec \"yarn mock-server\"",
    "contentful:provision-models": "node scripts/contentful/provision-models.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:ci": "jest --ci --passWithNoTests",
    "test:coverage": "jest --ci --coverage",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "contentful": "^11.12.5",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "json-server": "^0.17.4",
    "lint-staged": "16.2.6",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md,yml,yaml,html}": [
      "prettier --write"
    ]
  }
}
